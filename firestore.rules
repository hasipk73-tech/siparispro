rules_version = '2';
// firestore.rules — SiparisPro multi-tenant (orders, stokAlimlar, aramalar)
//
// İzolasyonu sunucuda zorlar. Frontend filtresi tek başına güvenlik DEĞİLDİR.
// Her order kaydında tenantId olur; kullanıcı sadece kendi tenant'ının
// siparişlerini görür/yazar. Süper admin (sen) hepsini görür.

service cloud.firestore {
  match /databases/{database}/documents {

    function userTenant() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId;
    }
    function isSuperAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol == "superadmin";
    }
    function ayniTenant() {
      return request.auth != null && resource.data.tenantId == userTenant();
    }
    // Yeni kayıt yazarken: eklenen tenantId, kullanıcının tenant'ı olmalı
    function yeniKayitGecerli() {
      return request.auth != null && request.resource.data.tenantId == userTenant();
    }

    // İşletme kayıtları
    match /tenants/{tenantId} {
      allow read:  if true;
      allow write: if request.auth != null;  // SuperAdminPanel kendi girişini yönetiyor
    }


    // Siparişler — tenant'a bağlı izolasyon
    match /orders/{orderId} {
      // Okuma: users kaydı olan personel/admin (tenant eşleşmeli) VEYA herhangi auth'lu kullanıcı
      allow read: if ayniTenant() || isSuperAdmin() || request.auth != null;

      // Oluşturma: auth varsa (anonim dahil), tenantId string ve dolu olmak şartıyla
      allow create: if request.auth != null
                    && request.resource.data.tenantId is string
                    && request.resource.data.tenantId.size() > 0;

      // Güncelleme/silme: users kaydı olan personel/superadmin VEYA
      // auth'lu kullanıcı (tenantId korunuyor — değiştirilemiyor)
      allow update, delete: if ayniTenant() || isSuperAdmin()
                            || (request.auth != null && resource.data.tenantId != null);
    }

    // Stok / palet alım kayıtları
    match /stokAlimlar/{kayitId} {
      allow read:          if ayniTenant() || isSuperAdmin();
      allow create:        if request.auth != null
                           && request.resource.data.tenantId is string
                           && request.resource.data.tenantId.size() > 0;
      allow update, delete: if ayniTenant() || isSuperAdmin();
    }

    // Arama kayıtları (IVR) — admin SDK server-side yazar, client okur
    match /aramalar/{aramaId} {
      allow read:   if ayniTenant() || isSuperAdmin();
      allow create: if request.auth != null
                    && request.resource.data.tenantId is string
                    && request.resource.data.tenantId.size() > 0;
      allow update: if ayniTenant() || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // Kullanıcılar
    match /users/{uid} {
      allow read:  if request.auth.uid == uid || isSuperAdmin();
      allow write: if isSuperAdmin();
    }
  }
}
